{
  "name": "attestia",
  "version": "2.0.0",
  "private": true,
  "description": "Financial truth infrastructure for the decentralized world",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r run test:coverage",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "lint": "pnpm -r lint",
    "bench": "pnpm -r run bench",
    "verify": "pnpm build && pnpm typecheck && pnpm test",
    "status": "node scripts/status.js",
    "clean": "pnpm -r exec rm -rf dist",
    "demo": "pnpm --filter @attestia/demo run demo"
  },
  "keywords": [
    "attestation",
    "web3",
    "financial-infrastructure",
    "structural-governance",
    "deterministic"
  ],
  "author": "mcp-tool-shop-org",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.4.0"
  }
}
